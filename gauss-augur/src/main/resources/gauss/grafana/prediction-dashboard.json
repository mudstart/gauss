{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping Micrometer metrics",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "Gauss — ML Prediction Metrics",
  "uid": "gauss-ml-predictions",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Prediction Throughput (calls/sec)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (model, status) (rate(dsml_prediction_count_total[$__rate_interval]))",
          "legendFormat": "{{model}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Prediction Latency p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (model, le) (rate(dsml_prediction_latency_seconds_bucket[$__rate_interval]))) * 1000",
          "legendFormat": "{{model}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (model, le) (rate(dsml_prediction_latency_seconds_bucket[$__rate_interval]))) * 1000",
          "legendFormat": "{{model}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (model, le) (rate(dsml_prediction_latency_seconds_bucket[$__rate_interval]))) * 1000",
          "legendFormat": "{{model}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "100 * sum(rate(dsml_prediction_count_total{status=\"error\"}[$__rate_interval])) / sum(rate(dsml_prediction_count_total[$__rate_interval]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Total Predictions (24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(increase(dsml_prediction_count_total{status=\"success\"}[24h]))",
          "legendFormat": "Predictions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "fixedColor": "blue", "mode": "fixed" } }
      }
    },
    {
      "id": 5,
      "title": "Mean Latency by Model (ms)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum by (model) (rate(dsml_prediction_latency_seconds_sum[$__rate_interval])) / sum by (model) (rate(dsml_prediction_latency_seconds_count[$__rate_interval])) * 1000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(dsml_prediction_count_total, model)",
        "multi": true,
        "includeAll": true
      }
    ]
  }
}
